<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_day_bg"
    android:layout_width="match_parent"
    android:layout_height="38dp"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:id="@+id/calendar_day_num"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#CBD5E1" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="5dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/dot_pending"
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_margin="1dp"
            android:background="@drawable/widget_dot_yellow"
            android:visibility="gone" />

        <View
            android:id="@+id/dot_completed"
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_margin="1dp"
            android:background="@drawable/widget_dot_green"
            android:visibility="gone" />

        <View
            android:id="@+id/calendar_day_dot"
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_margin="1dp"
            android:background="@drawable/widget_dot"
            android:visibility="gone" />

        <View
            android:id="@+id/dot_debt"
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_margin="1dp"
            android:background="@drawable/widget_dot_purple"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
